# ── Configurações gerais ──────────────────────────────────────────────────
Options -Indexes
ServerSignature Off

# PHP — aumenta limites de upload
<IfModule mod_php8.c>
    php_value upload_max_filesize 52M
    php_value post_max_size       55M
    php_value memory_limit        128M
    php_value max_execution_time  60
</IfModule>
<IfModule mod_php7.c>
    php_value upload_max_filesize 52M
    php_value post_max_size       55M
    php_value memory_limit        128M
    php_value max_execution_time  60
</IfModule>

# ── Bloquear acesso direto a config.php ──────────────────────────────────
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# ── Bloquear acesso à pasta uploads para execução de PHP ─────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquear execução de PHP dentro de /uploads/
    RewriteCond %{REQUEST_URI} ^/uploads/.*\.php$ [NC]
    RewriteRule .* - [F,L]

    # Bloquear execução de PHP dentro de /uploads/ com extensões duplas
    RewriteCond %{REQUEST_URI} ^/uploads/ [NC]
    RewriteCond %{REQUEST_FILENAME} \.(php|phtml|php3|php4|php5|phps|phar)$ [NC]
    RewriteRule .* - [F,L]
</IfModule>

# ── Headers de segurança ─────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "no-referrer"
</IfModule>

# ── Cache para assets estáticos ───────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css             "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/jpeg           "access plus 30 days"
    ExpiresByType image/png            "access plus 30 days"
    ExpiresByType image/webp           "access plus 30 days"
</IfModule>
